---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<BaseLayout
  title="About — Raz Cohen"
  description="Product Design Leader with 8+ years at Fiverr"
  activePage="about"
>
  <section class="about-section">
    <img
      src={`${base}images/Raz.jpg`}
      alt="Raz Cohen"
      class="about-photo"
      loading="eager"
    />
    <div class="about-text">
      <h1 class="about-heading">
        I'm a product design leader.<br />
        Always striving to create useful &amp; beautiful products while
        maintaining great balance between the business &amp; users need.
      </h1>
      <p class="about-para">
        For the past 8 years, I've worked as the Director of Product Design at
        Fiverr. During that time, I managed 25 people, including team leaders,
        product designers, and UX researchers. Part of my main achievements there
        included creating a well-structured, scalable design system, establishing
        the UX research team, creating a well-structured design process for my
        team and many other product and design initiatives as part of my vision
        to make Fiverr a leading company in terms of usability and design.
      </p>
      <p class="about-para">
        I previously worked as a designer for Hola and as a motion designer for
        Promotheos. I graduated from the visual communication department at
        Shenkar in 2010.
      </p>
      <p class="about-para">
        You can find my CV{' '}
        <a
          href="https://drive.google.com/file/d/1OOjyzZiJs97qVQXI350ZJJF_SUKB08no/view?usp=sharing"
          target="_blank"
          rel="noopener"
        >here</a>.
      </p>
    </div>
  </section>
</BaseLayout>
